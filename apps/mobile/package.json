{
  "name": "@trackit/mobile",
  "private": true,
  "version": "0.0.1",
  "description": "trackit native shell. Wraps the deployed web UI in a Capacitor app, adds background location tracking and native push notifications.",
  "type": "module",
  "scripts": {
    "sync": "cap sync",
    "sync:android": "cap sync android",
    "sync:ios": "cap sync ios",
    "open:android": "cap open android",
    "open:ios": "cap open ios",
    "run:android": "cap run android",
    "run:ios": "cap run ios",
    "add:android": "cap add android",
    "add:ios": "cap add ios",
    "doctor": "cap doctor",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.3.4",
    "@capacitor/ios": "^8.3.4",
    "@capacitor/preferences": "^8.0.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.4",
    "typescript": "^5.7.3"
  }
}
