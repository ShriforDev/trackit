{
  "name": "@trackit/api",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "bun --env-file=../../.env --hot run src/index.ts",
    "start": "bun --env-file=../../.env run src/index.ts",
    "typecheck": "tsc --noEmit",
    "auth:generate": "node --env-file=../../.env ./node_modules/@better-auth/cli/dist/index.mjs generate --config ./src/auth.ts --output ./src/db/schema.ts --y",
    "db:generate": "node --env-file=../../.env ./node_modules/drizzle-kit/bin.cjs generate",
    "db:migrate": "node --env-file=../../.env ./node_modules/drizzle-kit/bin.cjs migrate",
    "db:push": "node --env-file=../../.env ./node_modules/drizzle-kit/bin.cjs push --force",
    "db:studio": "node --env-file=../../.env ./node_modules/drizzle-kit/bin.cjs studio"
  },
  "dependencies": {
    "@trackit/shared": "workspace:*",
    "better-auth": "^1.2.0",
    "drizzle-orm": "^0.36.0",
    "hono": "^4.12.23",
    "ioredis": "^5.4.0",
    "nanoid": "^5.0.7",
    "nodemailer": "^6.9.16",
    "postgres": "^3.4.5",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.2.0",
    "@types/bun": "^1.1.0",
    "@types/nodemailer": "^6.4.17",
    "drizzle-kit": "^0.28.0",
    "typescript": "~5.9.3"
  }
}
