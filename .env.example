# --- Postgres (Better Auth + TimescaleDB) ---
POSTGRES_USER=trackit
POSTGRES_PASSWORD=change_me
POSTGRES_DB=trackit
# 5433 (not 5432) so we don't clash with a system-installed Postgres on the host.
POSTGRES_PORT=5433

# --- Tile38 (realtime geo store) ---
TILE38_HOST=localhost
TILE38_PORT=9851

# --- API (Bun + Hono) ---
API_PORT=3001
WEB_ORIGIN=http://localhost:5173

# Composed connection string for Drizzle / Better Auth.
# Keep in sync with the POSTGRES_* values above.
DATABASE_URL=postgres://trackit:change_me@localhost:5433/trackit

# --- Better Auth ---
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
BETTER_AUTH_SECRET=replace_with_32_byte_base64_secret
BETTER_AUTH_URL=http://localhost:3001

# --- Web (read by Vite — must be VITE_-prefixed to be exposed to the browser) ---
# Leave VITE_API_URL unset for dev. Vite's proxy (apps/web/vite.config.ts)
# routes /api, /devices, /fleet, and /ws to the API on localhost:3001 so the
# web app stays same-origin and works from a phone on the LAN without CORS
# tweaks. Only set this in production if the API runs on a different origin.
# VITE_API_URL=https://api.example.com

# --- SMTP (transactional email — invitations, etc.) ---
# Recommended: Gmail with an App Password.
#   1. Enable 2FA at https://myaccount.google.com/security
#   2. Create an app password at https://myaccount.google.com/apppasswords
#      (pick "Mail" + "Other / trackit"; copy the 16-char password)
#   3. Set SMTP_USER to your full Gmail address and SMTP_PASS to that app password.
#
# Leave SMTP_USER + SMTP_PASS blank to fall back to stdout-only logging
# (the [invite] line still prints with the URL, useful for local dev).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
# Defaults to SMTP_USER if blank.
SMTP_FROM=
SMTP_FROM_NAME=trackit
