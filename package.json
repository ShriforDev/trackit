{
  "name": "trackit",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "bun --filter @trackit/api --filter @trackit/web dev",
    "dev:web": "bun --filter @trackit/web dev",
    "dev:api": "bun --filter @trackit/api dev",
    "build:web": "bun --filter @trackit/web build",
    "lint:web": "bun --filter @trackit/web lint",
    "typecheck": "bun --filter '*' typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "infra:logs": "docker compose logs -f",
    "infra:reset": "docker compose down -v"
  },
  "devDependencies": {
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2"
  }
}
